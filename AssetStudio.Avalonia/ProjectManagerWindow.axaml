<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AssetStudio.Avalonia.ProjectManagerWindow"
        x:CompileBindings="False"
        Title="AssetStudio Projects"
        Icon="/Assets/as.png"
        Width="980" Height="620"
        MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="14">
        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                <Button x:Name="AddProjectButton" Click="AddProject_Click" MinWidth="128">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <PathIcon Data="{StaticResource icon_folder}" Width="16" Height="16" />
                        <TextBlock Text="Add project" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenWithoutProjectButton" Click="OpenWithoutProject_Click" MinWidth="152">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <PathIcon Data="{StaticResource icon_file}" Width="16" Height="16" />
                        <TextBlock Text="Open without project" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Projects" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Choose a workspace before loading assets." Opacity="0.68" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="16">
            <Border Grid.Column="0" BorderThickness="1" BorderBrush="Gray" Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Project list" FontWeight="SemiBold" Margin="4,0,0,8" />
                    <Grid Grid.Row="1">
                        <ListBox x:Name="ProjectListBox"
                                 SelectionChanged="ProjectListBox_SelectionChanged"
                                 DoubleTapped="ProjectListBox_DoubleTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="54,*" ColumnSpacing="10" Margin="4,6">
                                        <Border Width="46" Height="46" BorderThickness="1" BorderBrush="Gray" Padding="4">
                                            <Image Source="{Binding Icon}" Stretch="Uniform" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding RootDisplay}" FontSize="12" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding LastAccessedDisplay}" FontSize="12" Opacity="0.62" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="EmptyProjectsText"
                                   Text="No projects yet."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.7" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" BorderBrush="Gray" Padding="16">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="12">
                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Image x:Name="DetailIcon" DockPanel.Dock="Right" Width="72" Height="72" Stretch="Uniform" />
                        <StackPanel>
                            <TextBlock x:Name="DetailName" Text="Select a project" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="DetailSubtitle" Text="Project metadata appears here." Opacity="0.68" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" ColumnDefinitions="150,*" ColumnSpacing="12">
                        <TextBlock Text="Project root" FontWeight="SemiBold" />
                        <TextBlock x:Name="DetailRoot" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="150,*" ColumnSpacing="12">
                        <TextBlock Text="Last load folder" FontWeight="SemiBold" />
                        <TextBlock x:Name="DetailLastLoad" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="150,*" ColumnSpacing="12">
                        <TextBlock Text="Last export folder" FontWeight="SemiBold" />
                        <TextBlock x:Name="DetailLastExport" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="4" ColumnDefinitions="150,*" ColumnSpacing="12">
                        <TextBlock Text="Dates" FontWeight="SemiBold" />
                        <TextBlock x:Name="DetailDates" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="150,*" ColumnSpacing="12">
                        <TextBlock Text="Stats" FontWeight="SemiBold" />
                        <TextBlock x:Name="DetailStats" Grid.Column="1" Text="-" TextWrapping="Wrap" />
                    </Grid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button x:Name="EditProjectButton" Click="EditProject_Click" MinWidth="92" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <PathIcon Data="{StaticResource icon_settings}" Width="16" Height="16" />
                                <TextBlock Text="Edit" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RemoveProjectButton" Click="RemoveProject_Click" MinWidth="100" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <PathIcon Data="{StaticResource icon_extract}" Width="16" Height="16" />
                                <TextBlock Text="Remove" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenProjectButton" Click="OpenProject_Click" MinWidth="112" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <PathIcon Data="{StaticResource icon_preview}" Width="16" Height="16" />
                                <TextBlock Text="Open" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Opacity="0.72" TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>

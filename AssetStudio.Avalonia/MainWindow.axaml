<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:AssetStudio.Avalonia"
        xmlns:ffmpeg="using:AssetStudio.Avalonia.Controls"
        mc:Ignorable="d" d:DesignWidth="1264" d:DesignHeight="681"
        x:Class="AssetStudio.Avalonia.MainWindow"
        Title="AssetStudio (Avalonia Linux Port)"
        Icon="/Assets/as.png"
        Width="1264" Height="681"
        WindowStartupLocation="CenterScreen">
    
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Load file" Click="LoadFile_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_file}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Load folder" Click="LoadFolder_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_folder}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Extract file" Click="ExtractFile_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_extract}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Extract folder" Click="ExtractFolder_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_extract}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem x:Name="displayAll" Header="Display all assets" ToggleType="CheckBox" Click="DisplayAll_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_eye}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="enablePreview" Header="Enable preview" ToggleType="CheckBox" IsChecked="True" Click="EnablePreview_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_preview}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="displayInfo" Header="Display asset information" ToggleType="CheckBox" IsChecked="True" Click="DisplayInfo_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_info}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Set project root..." Click="SetProjectRoot_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_folder}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Specify Unity version">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_settings}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <TextBox x:Name="SpecifyUnityVersionTextBox" Width="140" PlaceholderText="2020.3.48f1" />
                </MenuItem>
                <MenuItem Header="Export options" Click="ShowExportOptions_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_settings}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Theme">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_theme}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem x:Name="themeDefault" Header="System Default" ToggleType="Radio" GroupName="ThemeGroup" Click="ThemeDefault_Click" />
                    <MenuItem x:Name="themeLight" Header="Light" ToggleType="Radio" GroupName="ThemeGroup" Click="ThemeLight_Click" />
                    <MenuItem x:Name="themeDark" Header="Dark" ToggleType="Radio" GroupName="ThemeGroup" Click="ThemeDark_Click" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Model">
                <MenuItem Header="Export all objects (split)" Click="ExportAllObjectsSplit_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Export selected objects (split)" Click="ExportSelectedObjectsSplit_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Export selected objects (split) + selected AnimationClips" Click="ExportSelectedObjectsSplitWithAnimationClip_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Export selected objects (merge)" Click="ExportSelectedObjectsMerge_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Export selected objects (merge) + selected AnimationClips" Click="ExportSelectedObjectsMergeWithAnimationClip_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Export">
                <MenuItem Header="All assets" Click="ExportAllAssets_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_export}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Selected assets" Click="ExportSelectedAssets_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_export}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Filtered assets" Click="ExportFilteredAssets_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_export}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Animator + selected AnimationClips" Click="ExportAnimatorWithSelectedAnimationClip_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_export}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Raw">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_cube}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="All assets" Click="ExportAllAssetsRaw_Click" />
                    <MenuItem Header="Selected assets" Click="ExportSelectedAssetsRaw_Click" />
                    <MenuItem Header="Filtered assets" Click="ExportFilteredAssetsRaw_Click" />
                </MenuItem>
                <MenuItem Header="Dump">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_file}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="All assets" Click="ExportAllAssetsDump_Click" />
                    <MenuItem Header="Selected assets" Click="ExportSelectedAssetsDump_Click" />
                    <MenuItem Header="Filtered assets" Click="ExportFilteredAssetsDump_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Asset list to XML">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_file}" Width="16" Height="16" />
                    </MenuItem.Icon>
                    <MenuItem Header="All assets" Click="ExportAllAssetsXML_Click" />
                    <MenuItem Header="Selected assets" Click="ExportSelectedAssetsXML_Click" />
                    <MenuItem Header="Filtered assets" Click="ExportFilteredAssetsXML_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Error log" Click="ExportErrorLog_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_info}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="filterTypeMenu" Header="Filter _Type">
                <MenuItem x:Name="filterTypeAll" Header="All" ToggleType="CheckBox" IsChecked="True" Click="FilterTypeAll_Click" />
            </MenuItem>
            <MenuItem Header="_Debug">
                <MenuItem x:Name="showErrorMessageMenu" Header="Show error message" ToggleType="CheckBox" Click="ShowErrorMessage_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_debug}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="exportClassStructuresMenu" Header="Export class structures" Click="ExportClassStructures_Click">
                    <MenuItem.Icon>
                        <PathIcon Data="{StaticResource icon_debug}" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="indexingMenu" Header="_Indexing" IsVisible="False">
                <MenuItem x:Name="pauseIndexingMenu" Header="Pause Indexing" Click="PauseIndexing_Click" />
                <MenuItem x:Name="resumeIndexingMenu" Header="Resume Indexing" Click="ResumeIndexing_Click" IsEnabled="False" />
                <MenuItem x:Name="stopIndexingMenu" Header="Stop/Cancel Indexing" Click="StopIndexing_Click" />
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*, Auto" Height="24" Margin="2,0">
            <ProgressBar x:Name="progressBar" Grid.Column="0" Height="20" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="statusLabel" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,4,0" Text="Ready" />
        </Grid>

        <Grid ColumnDefinitions="3*, 5, 7*">
            
            <TabControl x:Name="LeftTabControl" Grid.Column="0" Margin="2">
                <TabItem Header="Scene Hierarchy">
                    <Grid RowDefinitions="Auto, *">
                        <TextBox x:Name="treeSearch" Grid.Row="0" PlaceholderText=" Search " Margin="0,0,0,2" TextChanged="TreeSearch_TextChanged" KeyDown="TreeSearch_KeyDown"/>
                        <TreeView x:Name="SceneTreeView" Grid.Row="1" x:CompileBindings="False" AutoScrollToSelectedItem="True">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children, Mode=OneTime}" x:DataType="local:GameObjectNode" x:CompileBindings="True">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Focusable="False" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name, Mode=OneTime}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Asset List">
                    <Grid RowDefinitions="Auto, *">
                        <DockPanel Grid.Row="0" Margin="0,0,0,2">
                            <Button x:Name="ClearClassFilterButton" Content="Clear Class Filter" Click="ClearClassFilter_Click" IsVisible="False" DockPanel.Dock="Right" Margin="4,0,0,0" Padding="6,2"/>
                            <TextBox x:Name="listSearch" PlaceholderText=" Filter " TextChanged="ListSearch_TextChanged"/>
                        </DockPanel>
                        <DataGrid x:Name="AssetListDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" x:CompileBindings="False" SelectionChanged="AssetListDataGrid_SelectionChanged" CellPointerPressed="AssetListDataGrid_CellPointerPressed" Sorting="AssetListDataGrid_Sorting" CanUserResizeColumns="True" CanUserSortColumns="True" HorizontalScrollBarVisibility="Auto" SelectionMode="Extended">
                            <DataGrid.ContextMenu>
                                <ContextMenu Opened="AssetListContextMenu_Opened">
                                    <MenuItem Header="Copy text" Click="CopyAssetCellText_Click" />
                                    <MenuItem Header="Export selected assets" Click="ExportSelectedAssetsContext_Click" />
                                    <MenuItem x:Name="exportAnimatorWithSelectedAnimationClipMenuItem" Header="Export Animator + selected AnimationClips" Click="ExportAnimatorWithSelectedAnimationClip_Click" />
                                    <MenuItem x:Name="goToSceneHierarchyMenuItem" Header="Go to scene hierarchy" Click="GoToSceneHierarchy_Click" />
                                    <MenuItem x:Name="showOriginalFileMenuItem" Header="Show original file" Click="ShowOriginalFile_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="220" MinWidth="90" />
                                <DataGridTextColumn Header="Container" Binding="{Binding Container}" SortMemberPath="Container" Width="220" MinWidth="90" />
                                <DataGridTextColumn Header="Type" Binding="{Binding DisplayType}" SortMemberPath="DisplayType" Width="130" MinWidth="80" />
                                <DataGridTextColumn Header="PathID" Binding="{Binding PathID}" SortMemberPath="PathID" Width="210" MinWidth="120" />
                                <DataGridTextColumn Header="Size" Binding="{Binding FullSize}" SortMemberPath="FullSize" Width="90" MinWidth="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Asset Classes">
                    <Grid RowDefinitions="Auto, *">
                        <TextBox x:Name="classSearch" Grid.Row="0" PlaceholderText=" Filter classes " Margin="0,0,0,2" TextChanged="ClassSearch_TextChanged" />
                        <DataGrid x:Name="AssetClassesDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" x:CompileBindings="False" SelectionChanged="AssetClassesDataGrid_SelectionChanged" CanUserResizeColumns="True" CanUserSortColumns="True" HorizontalScrollBarVisibility="Auto">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Show instances in Asset List" Click="ShowClassInstances_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ClassID}" SortMemberPath="ClassID" Width="70" MinWidth="55" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="180" MinWidth="90" />
                                <DataGridTextColumn Header="Namespace" Binding="{Binding Namespace}" SortMemberPath="Namespace" Width="150" MinWidth="80" />
                                <DataGridTextColumn Header="Assembly" Binding="{Binding Assembly}" SortMemberPath="Assembly" Width="160" MinWidth="90" />
                                <DataGridTextColumn Header="Unity" Binding="{Binding UnityVersion}" SortMemberPath="UnityVersion" Width="110" MinWidth="80" />
                                <DataGridTextColumn Header="Objects" Binding="{Binding ObjectCount}" SortMemberPath="ObjectCount" Width="80" MinWidth="65" />
                                <DataGridTextColumn Header="Source" Binding="{Binding SourceKind}" SortMemberPath="SourceKind" Width="130" MinWidth="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Background="{DynamicResource SystemControlBorderBackgroundBrush}" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />

            <TabControl x:Name="RightTabControl" Grid.Column="2" Margin="2" SelectionChanged="RightTabControl_SelectionChanged">
                <TabItem Header="Preview">
                    <Panel Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">
                        <TextBox x:Name="TextPreviewBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" IsVisible="False" />
                        <Border x:Name="TextAssetPreviewPanel" Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsVisible="False">
                            <Grid RowDefinitions="Auto,*">
                                <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlBorderBackgroundBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Name="TextAssetPreviewTitle" Text="TextAsset" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock x:Name="TextAssetPreviewSubtitle" Text="" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Button x:Name="TextAssetCardsViewButton" Content="Cards" MinWidth="64" Height="28" Padding="10,4" HorizontalContentAlignment="Center" Click="TextAssetCardsViewButton_Click" />
                                            <Button x:Name="TextAssetDetailsViewButton" Content="Text" MinWidth="64" Height="28" Padding="10,4" HorizontalContentAlignment="Center" Click="TextAssetDetailsViewButton_Click" />
                                            <Button x:Name="TextAssetInfoViewButton" Content="Info" MinWidth="64" Height="28" Padding="10,4" HorizontalContentAlignment="Center" Click="TextAssetInfoViewButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1">
                                    <ScrollViewer x:Name="TextAssetDialogueScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="TextAssetDialogueCardsHost" Margin="16" Spacing="10" />
                                    </ScrollViewer>
                                    <TextBox x:Name="TextAssetDetailsTextBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" IsVisible="False" />
                                </Grid>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="PreviewLabel" Text="[Preview Panel]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <Image x:Name="ImagePreviewBox" Stretch="Uniform" StretchDirection="DownOnly" VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="False" />
                        <local:MeshPreviewControl x:Name="GLPreviewControl" IsVisible="False" Focusable="True" />
                        <local:TextureGLPreviewControl x:Name="TextureGLPreview" IsVisible="False" Focusable="True" />
                        <Border x:Name="PreviewInfoBorder" Background="#B0111111" BorderBrush="#33ffffff" BorderThickness="1" CornerRadius="6" Margin="10" Width="300" MaxHeight="500" HorizontalAlignment="Left" VerticalAlignment="Bottom" IsVisible="False">
                            <Grid RowDefinitions="Auto,*">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,4,8,4">
                                    <TextBlock Text="Mesh Information" VerticalAlignment="Center" Foreground="#AAA" FontWeight="Bold" FontSize="11" />
                                    <Button Grid.Column="1" x:Name="TogglePreviewInfoBtn" Content="▼" Width="24" Height="24" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" Foreground="White" BorderBrush="Transparent" Click="TogglePreviewInfoBtn_Click" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" x:Name="PreviewInfoScroll" MaxHeight="450" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="PreviewInfoOverlay" Foreground="White" FontFamily="Monospace" FontSize="11" LineHeight="15" Margin="8,0,8,8" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border x:Name="AnimationPlaybackPanel" Background="#B0111111" BorderBrush="#33ffffff" BorderThickness="1" CornerRadius="6" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Padding="8,4" IsVisible="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="AnimPlayPauseBtn" Content="Pause" Width="60" Height="28" FontSize="11" Click="AnimPlayPauseBtn_Click" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                <Button x:Name="AnimRestartBtn" Content="Replay" Width="60" Height="28" FontSize="11" Click="AnimRestartBtn_Click" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                <TextBlock x:Name="AnimFrameLabel" Text="Frame: 0/0" Foreground="White" VerticalAlignment="Center" FontSize="11" Margin="4,0" />
                            </StackPanel>
                        </Border>

                        <!-- Model Controls Panel -->
                        <Border x:Name="MeshViewerControlsPanel" Background="#B0111111" BorderBrush="#33ffffff" BorderThickness="1" CornerRadius="6" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8" IsVisible="{Binding #GLPreviewControl.IsVisible}">
                            <StackPanel Spacing="8" Width="180">
                                <TextBlock Text="Model Controls" Foreground="#AAA" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" />
                                
                                <!-- Reset View Button -->
                                <Button x:Name="ResetViewBtn" Content="Reset View" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="ResetViewBtn_Click" Height="28" FontSize="11" />
                                
                                <!-- Directional Rotation Buttons -->
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                                    <Button Grid.Column="0" x:Name="RotateLeftBtn" Content="◀" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="RotateLeftBtn_Click" Height="26" FontSize="10" ToolTip.Tip="Rotate Left 90°" />
                                    <Button Grid.Column="1" x:Name="RotateRightBtn" Content="▶" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="RotateRightBtn_Click" Height="26" FontSize="10" ToolTip.Tip="Rotate Right 90°" />
                                    <Button Grid.Column="2" x:Name="RotateUpBtn" Content="▲" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="RotateUpBtn_Click" Height="26" FontSize="10" ToolTip.Tip="Rotate Up 90°" />
                                    <Button Grid.Column="3" x:Name="RotateDownBtn" Content="▼" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="RotateDownBtn_Click" Height="26" FontSize="10" ToolTip.Tip="Rotate Down 90°" />
                                </Grid>
                                
                                <!-- Avatar Preview Sliders -->
                                <StackPanel x:Name="BoneSizeContainer" Spacing="6" IsVisible="False">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Bone Size" Foreground="White" FontSize="10" VerticalAlignment="Center" />
                                        <TextBlock x:Name="BoneSizeLabel" Grid.Column="1" Text="1.0x" Foreground="#AAA" FontSize="10" VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider x:Name="BoneSizeSlider" Minimum="0.1" Maximum="5.0" Value="1.0" Focusable="False" Height="24" ValueChanged="BoneSizeSlider_ValueChanged" />

                                    <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                        <TextBlock Text="Mesh Vertices" Foreground="White" FontSize="10" VerticalAlignment="Center" />
                                        <TextBlock x:Name="AvatarMeshDensityLabel" Grid.Column="1" Text="15%" Foreground="#AAA" FontSize="10" VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider x:Name="AvatarMeshDensitySlider" Minimum="1" Maximum="100" Value="15" TickFrequency="1" Focusable="False" Height="24" ValueChanged="AvatarMeshDensitySlider_ValueChanged" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="VideoClipPanel" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlBorderBackgroundBrush}" BorderThickness="1" CornerRadius="16" Padding="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10" IsVisible="False" BoxShadow="0 8 32 0 #40000000">
                            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="12">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="VideoTitleLabel" Text="Video Player" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="VideoStatusLabel" Grid.Column="1" Text="Ready" Foreground="#00e676" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <StackPanel Grid.Row="1" Spacing="4">
                                    <TextBlock x:Name="VideoResolutionLabel" Text="Resolution: 0x0" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                                    <TextBlock x:Name="VideoFrameRateLabel" Text="Frame Rate: 0 FPS" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                                    <TextBlock x:Name="VideoFormatLabel" Text="Format: Unknown" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                                    <TextBlock x:Name="VideoAudioLabel" Text="Audio: Checking..." Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                                    <TextBlock x:Name="VideoInfoLabel" Text="Loading preview..." Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <Border Grid.Row="2" Background="Black" CornerRadius="8" ClipToBounds="True" MinHeight="100">
                                    <Grid>
                                        <ffmpeg:VideoPlayerControl x:Name="FfmpegVideoPlayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ShowControls="False" ShowOpenButton="False" Volume="80" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,4">
                                    <Slider x:Name="VideoProgressBar" Minimum="0" Maximum="1000" Value="0" Focusable="False" Height="32"
                                            ValueChanged="VideoProgressBar_ValueChanged"/>
                                    <TextBlock x:Name="VideoTimerLabel" Grid.Column="1" Text="0:00.0 / 0:00.0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontFamily="Monospace" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                
                                <WrapPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="VideoPlayButton" Content="Play" Click="VideoPlayButton_Click" Width="60" HorizontalContentAlignment="Center" Margin="0,0,8,4"/>
                                    <Button x:Name="VideoStopButton" Content="Stop" Click="VideoStopButton_Click" Width="60" HorizontalContentAlignment="Center" Margin="0,0,8,4"/>
                                    <CheckBox x:Name="VideoLoopButton" Content="Loop" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center" Margin="0,0,16,4"/>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,4">
                                        <TextBlock Text="Vol" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                        <Slider x:Name="VideoVolumeBar" Minimum="0" Maximum="100" Value="80" Width="80" Focusable="False" VerticalAlignment="Center" ValueChanged="VideoVolumeBar_ValueChanged"/>
                                    </StackPanel>
                                    <Button x:Name="VideoExportButton" Content="Export" Click="VideoExportButton_Click" Width="70" HorizontalContentAlignment="Center" Margin="0,0,0,4"/>
                                </WrapPanel>
                            </Grid>
                        </Border>


                        <Border x:Name="FMODPanel" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlBorderBackgroundBrush}" BorderThickness="1" CornerRadius="16" Padding="20" HorizontalAlignment="Stretch" VerticalAlignment="Center" MaxWidth="450" Margin="10" IsVisible="False" BoxShadow="0 8 32 0 #40000000">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="FMODTitleLabel" Text="Audio Player" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FMODstatusLabel" Grid.Column="1" Text="Stopped" Foreground="#00e676" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="FMODinfoLabel" Text="44100 Hz" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FMODtimerLabel" Grid.Column="1" Text="0:00.0 / 0:00.0" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" FontFamily="Monospace" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <Slider x:Name="FMODprogressBar" Grid.Row="2" Minimum="0" Maximum="1000" Value="0" Focusable="False" Height="32" 
                                        ValueChanged="FMODprogressBar_ValueChanged"/>
                                
                                <WrapPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="FMODplayButton" Content="Play" Click="FMODplayButton_Click" Width="55" HorizontalContentAlignment="Center" Margin="0,0,8,4"/>
                                    <Button x:Name="FMODpauseButton" Content="Pause" Click="FMODpauseButton_Click" Width="65" HorizontalContentAlignment="Center" Margin="0,0,8,4"/>
                                    <Button x:Name="FMODstopButton" Content="Stop" Click="FMODstopButton_Click" Width="55" HorizontalContentAlignment="Center" Margin="0,0,8,4"/>
                                    <CheckBox x:Name="FMODloopButton" Content="Loop" Click="FMODloopButton_Click" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center" Margin="0,0,16,4"/>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                                        <TextBlock Text="Vol" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                        <Slider x:Name="FMODvolumeBar" Minimum="0" Maximum="10" Value="8" Width="80" Focusable="False" VerticalAlignment="Center" ValueChanged="FMODvolumeBar_ValueChanged"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Panel>
                </TabItem>
                <TabItem Header="Dump">
                    <TextBox x:Name="DumpTextBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" FontFamily="Monospace" />
                </TabItem>
            </TabControl>

        </Grid>
    </DockPanel>
</Window>
